# Frontend environment variables
# All Vite env vars must start with VITE_

# Backend URL — use localhost for dev, LAN IP for multi-device on hotspot
# e.g. VITE_BACKEND_URL=http://192.168.1.100:3001
VITE_BACKEND_URL=http://localhost:3001

# Campground map centre coordinates (Redemption City)
VITE_MAP_CENTER_LAT=6.6521
VITE_MAP_CENTER_LNG=3.4312
VITE_MAP_DEFAULT_ZOOM=16
