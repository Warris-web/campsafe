# ─── Server ───────────────────────────────────────────────
PORT=3001

# ─── MongoDB (Local — always used for offline operation) ──
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/campsafe

# ─── MongoDB Atlas (optional — cloud sync when online) ────
# Leave blank to disable Atlas sync
MONGO_ATLAS_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/campsafe?retryWrites=true&w=majority

# ─── Serial Port ──────────────────────────────────────────
# Windows: COM3  |  Linux/Mac: /dev/ttyUSB0 or /dev/cu.usbserial-xxxx
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=115200

# ─── Feature Flags ────────────────────────────────────────
# Set to true to enable Atlas sync when internet is available
ENABLE_ATLAS_SYNC=false

# Set to true to simulate fake tracker data (no hardware needed)
SIMULATE_HARDWARE=false
